# Copiar a secret.yaml y rellenar valores. No commitear secret.yaml.
# kubectl create secret generic sercop-api-secret --from-literal=DATABASE_URL=postgresql://... --from-literal=REDIS_URL=redis://...
# o aplicar este archivo tras sustituir los placeholders (base64).
apiVersion: v1
kind: Secret
metadata:
  name: sercop-api-secret
  labels:
    app: sercop-api
type: Opaque
stringData:
  DATABASE_URL: "postgresql://USER:PASSWORD@HOST:5432/DBNAME"
  REDIS_URL: "redis://redis-host:6379"
  JWT_SECRET: "your-min-16-char-secret"
  # Opcional (Fase 4 documentos)
  # S3_ENDPOINT: "https://minio.example.com"
  # S3_ACCESS_KEY: "..."
  # S3_SECRET_KEY: "..."
  # S3_BUCKET: "sercop-docs"
