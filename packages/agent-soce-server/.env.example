# Agent SOCE Chat 2.0 — Environment Variables
# Copy to .env and fill in the values.

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3090

# ─── Agent SOCE Database (own PostgreSQL + pgvector + AGE) ───────────────────
DATABASE_URL=postgresql://agent_soce:agent_soce@localhost:5433/agent_soce

# ─── Host Database (transactional DB, read-only) ─────────────────────────────
HOST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sercop

# ─── Redis (session state) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6381

# ─── Ollama (local LLM + embeddings) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
AGENT_SOCE_LLM_PROVIDER=ollama
AGENT_SOCE_LLM_MODEL=llama3.2:3b
AGENT_SOCE_EMBEDDING_PROVIDER=ollama
AGENT_SOCE_EMBEDDING_MODEL=nomic-embed-text

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars

# ─── Optional: External LLM API Keys ─────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=AIza...

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all)
# CORS_ALLOWED_ORIGINS=http://localhost:3004,http://localhost:3080

# ─── Rate Limit ──────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=120
