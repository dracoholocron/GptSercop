{
  "name": "gpt-sercop",
  "version": "0.1.0",
  "private": true,
  "description": "SERCOP V2 – Plataforma de contratación pública",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=api",
    "dev:public-portal": "npm run dev --workspace=public-portal",
    "dev:supplier-portal": "npm run dev --workspace=supplier-portal",
    "dev:entity-portal": "npm run dev --workspace=entity-portal",
    "dev:admin": "npm run dev --workspace=sercop-admin",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace=api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:generate": "npm run db:generate --workspace=api",
    "db:push": "npm run db:push --workspace=api",
    "db:seed": "npm run db:seed --workspace=api",
    "db:setup": "npm run db:push --workspace=api && npm run db:seed --workspace=api",
    "smoke": "node scripts/smoke.js",
    "crawler": "node scripts/crawler/index.js",
    "crawler:seed": "node scripts/crawler/index.js --seed",
    "crawler:import": "npm run crawler:import --workspace=api",
    "rag-index": "node scripts/rag-index.js",
    "test:integration": "npm run test:integration --workspace=api",
    "test:security": "npm run test:security --workspace=api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "evidence": "playwright test e2e/evidence.spec.ts --config=playwright.evidence.config.ts",
    "ports:kill": "node scripts/kill-ports.js",
    "audit": "npm audit --workspaces"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.58.2"
  }
}
