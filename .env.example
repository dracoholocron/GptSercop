# ===========================================
# API (puerto 3080) – desarrollo y producción
# ===========================================
# DATABASE_URL=postgresql://user:pass@localhost:5432/sercop
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=your-secret-min-16-chars
# PORT=3080

# Producción: JWT_SECRET mínimo 16 caracteres; no exponer en repositorio.
# Secretos (DATABASE_URL, REDIS_URL, S3_*, JWT_SECRET) en Secret/gestor de secretos.

# CORS: en producción definir orígenes permitidos (separados por coma).
# Ejemplo: https://app.sercop.gob.ec,https://admin.sercop.gob.ec
# Si no se define, se usa origin: true (solo para desarrollo).
# CORS_ALLOWED_ORIGINS=

# Almacenamiento documentos (MinIO/S3)
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=sercop-docs
# S3_USE_SSL=false

# ===========================================
# Portales Next.js – producción
# ===========================================
# NEXT_PUBLIC_API_URL debe apuntar a la URL pública de la API (no localhost en producción).
# NEXT_PUBLIC_API_URL=http://localhost:3080
# NEXT_PUBLIC_SUPPLIER_URL=http://localhost:3002
# NEXT_PUBLIC_PUBLIC_URL=http://localhost:3001

# ===========================================
# Crawler
# ===========================================
# CRAWLER_API_URL=http://localhost:3080
# CRAWLER_OCDS_URL=https://datosabiertos.compraspublicas.gob.ec/PLATAFORMA/api
