# ─── SERCOP Frontend — Environment Variables ─────────────────────────────────
# Copy this file to .env.local for local development
# Copy to .env.production for production builds

# Backend API URL (host application backend, Node.js)
VITE_DEV_PROXY_TARGET=http://localhost:3080

# Enable/disable the old CMX Chat widget
VITE_ENABLE_CMX_CHAT=false

# ─── Agent SOCE Chat 2.0 ─────────────────────────────────────────────────────
# URL of the standalone Agent SOCE backend (Fastify, port 3090 by default)
# Development:  http://localhost:3090
# Production:   http://<server-ip>:3090  or  https://agent-soce.yourdomain.com
VITE_AGENT_SOCE_API_URL=http://localhost:3090
