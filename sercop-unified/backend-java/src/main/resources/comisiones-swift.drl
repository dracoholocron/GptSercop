        $m : MensajeSWIFT(tipoMensaje == "MT760",
                          evento == "GUARANTEE_ISSUANCE",
                          monto >= 1000000.0,
                          moneda == "USD",
                          paisOrigen == "EC")
        $c : ConfiguracionComision()
    then
        $c.setComisionFija(0.0);
        $c.setComisionPorcentaje(0.12);
        $c.setComisionMinima(500.0);
        $c.setComisionMaxima(5000.0);
end

rule "Regla_MT760_GUARANTEE_ISSUANCE_48"
    when
        $m : MensajeSWIFT(tipoMensaje == "MT760",
                          evento == "GUARANTEE_ISSUANCE",
                          monto < 200000.0,
                          moneda == "EUR",
                          paisOrigen == "EC")
        $c : ConfiguracionComision()
    then
        $c.setComisionFija(350.0);
        $c.setComisionPorcentaje(0.0);
        $c.setComisionMinima(280.0);
        $c.setComisionMaxima(1600.0);
end

