-- Campo: 32B - Monto de la Carta de Crédito (OBLIGATORIO)
INSERT INTO swift_field_config (
    field_code, field_name, description, message_type, section, display_order,
    is_required, is_active, field_type, component_type, placeholder,
    validation_rules, dependencies, contextual_alerts, field_options,
    default_value, help_text, documentation_url, created_by
) VALUES (
    ':32B:',
    'Monto de la LC',
    'Monto y moneda de la carta de crédito',
    'MT700',
    'MONTOS',
    1,
    true,
    true,
    'CURRENCY',
    'CURRENCY_AMOUNT_INPUT',
    'Ingrese el monto de la LC',
    '{"minValue": 0.01, "maxValue": 99999999.99, "required": true, "errorMessage": "El monto de la LC es obligatorio y debe ser mayor a 0"}',
    '{"triggers": [":39A:", ":39B:", ":39C:"], "revalidates": [":39B:", ":39C:"]}',
    NULL,
    NULL,
    null,
    'Monto principal de la carta de crédito según norma SWIFT MT700',
    'https://www2.swift.com/knowledgecentre/publications/us7m_20230720/2.0?topic=idx_fld_tag_32B.htm',
    'SYSTEM'
);

-- Campo: 39A - Tolerancia Porcentual (OPCIONAL)
INSERT INTO swift_field_config (
    field_code, field_name, description, message_type, section, display_order,
    is_required, is_active, field_type, component_type, placeholder,
    validation_rules, dependencies, contextual_alerts, field_options,
    default_value, help_text, documentation_url, created_by
) VALUES (
    ':39A:',
    'Tolerancia Porcentual',
    'Porcentaje de tolerancia permitido (+/-)',
    'MT700',
    'MONTOS',
    2,
    false,
    true,
    'TEXT',
    'INPUT',
    'Ej: +10%, -5%, +10/-5%',
    '{"pattern": "^[+-]?\\d{1,2}(\\.\\d{1,2})?%(\\/[+-]?\\d{1,2}(\\.\\d{1,2})?%)?$", "customValidator": "toleranceValidator", "errorMessage": "Formato inválido. Ejemplos válidos: +10%, -5%, +10/-5%"}',
    '{"triggers": [":32B:"], "disabledIf": {"field": ":39B:", "condition": "NOT_EMPTY", "operator": "OR", "field2": ":39C:", "condition2": "NOT_EMPTY"}}',
    '[{"condition": "HAS_VALUE", "severity": "INFO", "message": "La tolerancia porcentual permite variaciones en el monto de la LC"}]',
    NULL,
    null,
    'Tolerancia permitida para el monto de la LC. No se puede usar junto con Monto Máximo o Adicional',
    'https://www2.swift.com/knowledgecentre/publications/us7m_20230720/2.0?topic=idx_fld_tag_39A.htm',
    'SYSTEM'
);

-- Campo: 39B - Monto Máximo (OPCIONAL)
INSERT INTO swift_field_config (
    field_code, field_name, description, message_type, section, display_order,
    is_required, is_active, field_type, component_type, placeholder,
    validation_rules, dependencies, contextual_alerts, field_options,
    default_value, help_text, documentation_url, created_by
) VALUES (
    ':39B:',
    'Monto Máximo',
    'Monto máximo permitido',
    'MT700',
    'MONTOS',
    3,
    false,
    true,
    'DECIMAL',
    'INPUT',
    'Ingrese el monto máximo',
    '{"minValue": 0.01, "customValidator": "maxAmountValidator", "errorMessage": "El monto máximo debe ser mayor al monto de la LC"}',
    '{"triggers": [":32B:"], "requiredIf": {"field": ":39C:", "condition": "NOT_EMPTY"}, "disabledIf": {"field": ":39A:", "condition": "NOT_EMPTY"}}',
    '[{"condition": "GREATER_THAN", "field": ":32B:", "severity": "INFO", "message": "Se ha establecido un monto máximo mayor al monto de la LC", "suggestedFields": [":39C:"]}]',
    NULL,
    null,
    'Monto máximo permitido para la LC. No se puede usar junto con Tolerancia Porcentual',
    'https://www2.swift.com/knowledgecentre/publications/us7m_20230720/2.0?topic=idx_fld_tag_39B.htm',
    'SYSTEM'
);

